# Temporary localhost-only host port for VPS Nginx until BFF/reverse proxy is ready.
# Docker publishes 127.0.0.1:<port>:8083, not a public <vps-ip>:<port> listener.
LEARNING_SERVICE_PORT=8083

# Shared external Docker network for BFF/UserService/CourseService/LearningService.
# Create it once with: docker network create studybytes_backend_net
LEARNING_BACKEND_NETWORK=studybytes_backend_net

# Private LearningService DB network. Do not create it manually; docker compose creates it.
LEARNING_DB_NETWORK=learning_db_net

LEARNING_SERVICE_DB_NAME=learning_service
LEARNING_SERVICE_DB_USERNAME=postgres
LEARNING_SERVICE_DB_PASSWORD=change-me
LEARNING_SERVICE_DB_URL=jdbc:postgresql://learning-postgres:5432/learning_service

# LearningService runtime
SERVER_PORT=8083
SPRING_DATASOURCE_URL=jdbc:postgresql://learning-postgres:5432/learning_service
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false

# LearningService verifies JWTs through UserService public JWKS endpoint.
# Do not put UserService private keys or JWT signing secrets into LearningService.
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://user-service:8081
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://user-service:8081/api/v1/auth/.well-known/jwks.json
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_AUDIENCES=study-platform

# CodeRunner integrations
CODERUNNER_COURSE_SERVICE_BASE_URL=http://course-service:8082
CODERUNNER_COURSE_SERVICE_INTERNAL_API_KEY_HEADER=X-Internal-API-Key
CODERUNNER_COURSE_SERVICE_INTERNAL_API_KEY=change-me-internal-api-key
CODERUNNER_EXECUTOR_SERVICE_BASE_URL=http://code-executor-service:8084
CODERUNNER_EXECUTOR_SERVICE_AUTH_TOKEN=change-me-executor-token

SPRING_PROFILES_ACTIVE=prod
