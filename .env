# Host ports
LEARNING_SERVICE_HOST_PORT=8083
POSTGRES_HOST_PORT=6767
CODE_EXECUTOR_HOST_PORT=8084

# Postgres
POSTGRES_DB=learning_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# LearningService runtime
SERVER_PORT=8083
CODE_EXECUTOR_SERVER_PORT=8084
SPRING_DATASOURCE_URL=jdbc:postgresql://learning-postgres:5432/learning_service
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=study-platform-user-service
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://host.docker.internal:8081/api/v1/auth/.well-known/jwks.json
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_AUDIENCES=study-platform

# CodeRunner integrations
CODERUNNER_COURSE_SERVICE_BASE_URL=http://host.docker.internal:8082
CODERUNNER_COURSE_SERVICE_INTERNAL_API_KEY_HEADER=X-Internal-API-Key
CODERUNNER_COURSE_SERVICE_INTERNAL_API_KEY=change-me-internal-api-key
CODERUNNER_EXECUTOR_SERVICE_BASE_URL=http://code-executor-service:8084
CODERUNNER_EXECUTOR_SERVICE_AUTH_TOKEN=dev-executor-service-token
